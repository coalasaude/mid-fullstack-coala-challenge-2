generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ATTENDANT
  DOCTOR
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  role         Role
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastAccessAt DateTime?
}
