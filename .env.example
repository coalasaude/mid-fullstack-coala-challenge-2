# --- Nginx (only public-facing port) ---
NGINX_HTTP_PORT=80

# --- Frontend build args ---
# When running behind this nginx, use the relative path "/api" so the browser
# talks back to nginx on the same origin (nginx proxies /api -> backend:3000).
NEXT_PUBLIC_API_URL=/api

# --- PostgreSQL ---
POSTGRES_USER=healthflow
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=healthflow

# --- RabbitMQ ---
RABBITMQ_USER=healthflow
RABBITMQ_PASSWORD=change-me-strong-password

# --- JWT ---
JWT_SECRET=replace-with-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# --- Message queues ---
EXAM_PROCESSING_QUEUE=exam_processing_queue
EXAM_PROCESSING_DLQ=exam_processing_dlq
EXAM_PROCESSING_RETRY_QUEUE=exam-processing.retry
USER_ACCESS_LOG_QUEUE=user-access.log.events
USER_ACCESS_LOG_DLQ=user-access.log.events.dlq
USER_ACCESS_LOG_RETRY_QUEUE=user-access.log.retry

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET=
AWS_BUCKET_URL=
